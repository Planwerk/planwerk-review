{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReviewResult",
  "description": "Contract for the `review` and `audit` --format json output (report.ReviewResult). The audit path reuses ReviewResult, so both commands share this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": ["findings", "summary", "recommendation"],
  "properties": {
    "findings": {
      "description": "Findings ordered by severity. Encoded as null (not []) when there are none.",
      "type": ["array", "null"],
      "items": { "$ref": "#/$defs/finding" }
    },
    "summary": { "type": "string" },
    "recommendation": { "type": "string" }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "title", "file", "problem", "action"],
      "properties": {
        "id": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["BLOCKING", "CRITICAL", "WARNING", "INFO"]
        },
        "title": { "type": "string" },
        "file": { "type": "string" },
        "line": { "type": "integer" },
        "line_end": { "type": "integer" },
        "pattern": { "type": "string" },
        "actionability": {
          "type": "string",
          "enum": ["auto-fix", "needs-discussion", "architectural"]
        },
        "fix_class": {
          "type": "string",
          "enum": ["AUTO-FIX", "ASK"]
        },
        "confidence": {
          "type": "string",
          "enum": ["verified", "likely", "uncertain"]
        },
        "problem": { "type": "string" },
        "action": { "type": "string" },
        "code_snippet": { "type": "string" },
        "suggested_fix": { "type": "string" },
        "fix_options": {
          "type": "array",
          "items": { "$ref": "#/$defs/fixOption" }
        },
        "recommended_option": { "type": "string" },
        "recommendation_reasoning": { "type": "string" },
        "related_to": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confirmed_by": {
          "type": "array",
          "items": { "type": "string" }
        },
        "verification_note": { "type": "string" }
      }
    },
    "fixOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "approach"],
      "properties": {
        "id": { "type": "string" },
        "approach": { "type": "string" },
        "pros": { "type": "string" },
        "cons": { "type": "string" },
        "effort": { "type": "string" },
        "risk_if_skipped": { "type": "string" }
      }
    }
  }
}
